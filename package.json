{
  "name": "eslint-plugin-promise",
  "version": "9.0.0",
  "description": "Enforce best practices for JavaScript promises",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "promise",
    "promises"
  ],
  "homepage": "https://github.com/Aesthermortis/eslint-plugin-promise",
  "bugs": "https://github.com/Aesthermortis/eslint-plugin-promise/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/Aesthermortis/eslint-plugin-promise"
  },
  "funding": "https://opencollective.com/eslint",
  "license": "ISC",
  "author": "Aesthermortis",
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./index.d.ts",
  "files": [
    "dist",
    "docs",
    "index.d.ts",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "prebuild": "node -e \"const fs=require('node:fs'); for (const dir of ['dist']) fs.rmSync(dir,{recursive:true,force:true});\"",
    "build": "rollup -c",
    "docs:check": "eslint-doc-generator --check",
    "predocs:update": "npm run build",
    "docs:update": "eslint-doc-generator",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --cache --cache-strategy content --cache-location .cache/eslint/ --report-unused-disable-directives",
    "lint:all": "npm run lint:fix && npm run docs:update",
    "lint:fix": "eslint . --fix --cache --cache-strategy content --cache-location .cache/eslint/ --report-unused-disable-directives",
    "prepack": "npm run build",
    "prepare": "husky && npm run build",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --coverage",
    "test:watch": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@eslint-community/eslint-utils": "^4.9.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^8.0.1",
    "@homer0/prettier-plugin-jsdoc": "^11.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/eslint-plugin-security": "^3.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-doc-generator": "^3.3.2",
    "eslint-plugin-eslint-plugin": "^7.3.2",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-packagejson": "^3.0.2",
    "rollup": "^4.60.2",
    "rollup-plugin-dts": "^6.4.1",
    "typescript": "~6.0.3"
  },
  "peerDependencies": {
    "eslint": "^10.0.0"
  },
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  }
}
