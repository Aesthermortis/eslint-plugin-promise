{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "target": "es2024",
    "types": ["node", "jest"]
  },
  "include": [
    "src/**/*.js",
    "__tests__/**/*.js",
    "eslint.config.js",
    "rollup.config.js",
    "index.d.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
